DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nevo
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nevo_test
AUTH_PASSWORD_PEPPER=replace-with-at-least-32-random-characters
AUTH_PIN_PEPPER=replace-with-a-different-32-character-secret
AUTH_SESSION_PEPPER=replace-with-another-32-character-secret
