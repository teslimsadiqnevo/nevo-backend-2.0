AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-2.5-flash
AI_REQUESTS_PER_MINUTE=60
AI_MAX_CONCURRENCY=4
AI_INPUT_COST_USD_PER_MILLION=0
AI_OUTPUT_COST_USD_PER_MILLION=0
